# =============================================================================
# AI SDLC — Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=sdlc
POSTGRES_PASSWORD=changeme

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Redis ---
REDIS_PASSWORD=changeme

# --- Redmine ---
REDMINE_SECRET=please_change_this_to_a_long_random_string

# --- Model API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...         # Optional: if routing to GPT models
# GROQ_API_KEY=gsk_...          # Optional: for open-source model inference via Groq
# TOGETHER_API_KEY=...          # Optional: for open-source model inference via Together

# --- GitHub ---
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo-name

# --- Redmine API ---
REDMINE_URL=http://localhost:3000
REDMINE_API_KEY=                 # Set after first Redmine login → My Account → API key
